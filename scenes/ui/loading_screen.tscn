[sub_resource type="Shader" id="Shader_white"]
code = "shader_type canvas_item;\n\nvoid fragment() {\n    vec2 pixel = TEXTURE_PIXEL_SIZE * 2.5;\n    float body = texture(TEXTURE, UV).a;\n    float glow = 0.0;\n    glow = max(glow, texture(TEXTURE, UV + vec2(pixel.x, 0.0)).a);\n    glow = max(glow, texture(TEXTURE, UV - vec2(pixel.x, 0.0)).a);\n    glow = max(glow, texture(TEXTURE, UV + vec2(0.0, pixel.y)).a);\n    glow = max(glow, texture(TEXTURE, UV - vec2(0.0, pixel.y)).a);\n    glow = max(glow, texture(TEXTURE, UV + pixel).a);\n    glow = max(glow, texture(TEXTURE, UV - pixel).a);\n    float alpha = max(body, glow * 0.42);\n    COLOR = vec4(1.0, 1.0, 1.0, alpha);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_white"]
shader = SubResource("Shader_white")

[sub_resource type="Shader" id="Shader_shutter"]
code = "shader_type canvas_item;\n\nuniform float aperture : hint_range(0.0, 1.35) = 1.35;\nuniform float edge_slant : hint_range(-0.2, 0.2) = 0.075;\n\nvoid fragment() {\n    vec2 centered = UV - vec2(0.5);\n    float slanted_x = centered.x + centered.y * edge_slant;\n    float half_width = aperture * 0.5;\n    float inside_aperture = 1.0 - step(half_width, abs(slanted_x));\n    COLOR = vec4(0.0, 0.0, 0.0, 1.0 - inside_aperture);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_shutter"]
resource_local_to_scene = true
